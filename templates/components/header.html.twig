{% import "/macros/macros.html.twig" as macros %}


<section class="header">
    <div class="header-contact-bg show-desktop">
        {{ macros.renderContactMenuItems() }}
    </div>
    <div class="header-navigation-bg">
        <div class="container">
            <div class="header-navigation">
                <a href="{{ path('front_homepage') }}"><img src="{{ asset("./build/images/stabilius-logo.png") }}" class="header-logo" alt="Logo"/></a>
                <nav class="navbar navbar-expand-lg">
                    <div class="menu-item nav-search-click show-mobile">
                        <span class="nav-link nav-search-butt" href="#"><i id="nav-search-butt-icon" class="icon icon-search"></i></span>
                    </div>
                    <div class="menu-item navigation-toggler show-mobile">
                        <span class="nav-link" href="#"><i id="navbar-toggler-icon" class="icon icon-menu-mobile"></i></span>
                    </div>

                    <div class="show-desktop" id="navbar">
                        {{ macros.renderNavigationItems() }}
                    </div>
                </nav>
            </div>
        </div>
    </div>
    <div class="desktop-search-bar">
        <div class="search-wrapper">
            <input name="search-reality" id="search-reality" class="search-reality-top-d text-md" placeholder="Vyhledat nemovitost" alt="Search reality" />
            <button class="btn search-reality-butt search-js text-sm">
                <i class="icon icon-search"></i>
                Vyhledat
            </button>
        </div>
    </div>
    <div class="show-tablet show-mobile mobile-nav-bar">
        {{ macros.renderNavigationItems() }}
        <div class="header-contact-bg">
            {{ macros.renderContactMenuItems() }}
        </div>
    </div>
</section>


<!-- Modal -->
<div class="modal fade" id="staticBackdrop" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="staticBackdropLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h1 class="modal-title fs-5" id="staticBackdropLabel">Prodat nemovitost</h1>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                {{ macros.renderContactForm() }}
            </div>
{#            <div class="modal-footer">#}
{#                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>#}
{#                <button type="button" class="btn btn-primary">Understood</button>#}
{#            </div>#}
        </div>
    </div>
</div>
